# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values
# DO NOT commit .env to source control
# ─────────────────────────────────────────────────────────────────────────────

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# ── Azure Speech (TTS / multilingual voice output) ───────────────────────────
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=centralindia

# ── Azure AI Foundry — Cohere Reranker (optional) ────────────────────────────
AZURE_RERANK_URL=https://your-endpoint.inference.ai.azure.com/v1/rank
AZURE_RERANK_KEY=your_azure_rerank_api_key
RERANK_K=5

# ── Qdrant Cloud ──────────────────────────────────────────────────────────────
QDRANT_CLOUD_URL=https://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.aws.cloud.qdrant.io:6333
QDRANT_CLOUD_API_KEY=your_qdrant_cloud_api_key
QDRANT_COLLECTION=schemes_hybrid

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION_NAME=eu-north-1
# S3 buckets for voice input / output
S3_VOICE_INPUT_BUCKET=whatsapp-voice-messages
S3_VOICE_OUTPUT_BUCKET=whatsapp-voice-responses

# ── Bedrock ───────────────────────────────────────────────────────────────────
BEDROCK_LLM_MODEL=eu.amazon.nova-lite-v1:0

# ── SageMaker (optional — for GPU embeddings instead of fastembed CPU) ────────
SAGEMAKER_ENDPOINT=

# ── AWS Transcribe ────────────────────────────────────────────────────────────
TRANSCRIBE_S3_BUCKET=government-scheme

# ── Lambda function names ─────────────────────────────────────────────────────
AWS_LAMBDA_FUNCTION_NAME=vani-jan-webhook
